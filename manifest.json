{
  "manifest_version": 3,
  "name": "久坐提醒助手",
  "version": "2.0.0",
  "description": "定时提醒你不要久坐，起来活动活动身体 - 支持番茄工作法",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["notification.wav", "ding.wav", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
